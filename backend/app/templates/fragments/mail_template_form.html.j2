{% set t = tpl %}
<form hx-put="/mail-templates/{{ t.id }}"
      hx-target="#mail-tpl-{{ t.id }}"
      hx-swap="innerHTML">

  <div class="form-group mt-1">
    <label class="form-label form-label--required" for="subject-{{ t.id }}">Betreff</label>
    <input id="subject-{{ t.id }}" name="subject" type="text" class="form-input {% if errors and errors.subject %}form-input--error{% endif %}"
           value="{{ t.subject }}" required>
    {% if errors and errors.subject %}<span class="form-error">{{ errors.subject }}</span>{% endif %}
  </div>

  <div class="form-group mt-1">
    <label class="form-label form-label--required" for="body-{{ t.id }}">Inhalt</label>
    <textarea id="body-{{ t.id }}" name="body" class="form-textarea {% if errors and errors.body %}form-textarea--error{% endif %}"
              style="min-height:200px" required>{{ t.body }}</textarea>
    {% if errors and errors.body %}<span class="form-error">{{ errors.body }}</span>{% endif %}
    <span class="form-hint">Jinja2-Variablen: {{ '{{' }} invoice_number {{ '}}' }}, {{ '{{' }} customer_name {{ '}}' }}, {{ '{{' }} amount {{ '}}' }}, …</span>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn--primary">Speichern</button>
  </div>
</form>

{% include "fragments/reconciliation_nav.html.j2" %}

<div class="page-header">
  <h1 class="page-title">CAMT-Import</h1>
</div>

<form action="/reconciliation/import" method="post" enctype="multipart/form-data"
      hx-post="/reconciliation/import" hx-target="#import-result" hx-encoding="multipart/form-data">
  <div class="form-group">
    <label class="form-label" for="file">CAMT.053-Datei (.xml)</label>
    <input type="file" id="file" name="file" accept=".xml" class="form-input" required>
  </div>
  <button type="submit" class="btn btn-primary">Importieren</button>
</form>

<div id="import-result"></div>

{% if history %}
<h2 class="section-title mt-2">Importverlauf</h2>
<div class="table-wrapper mt-1">
  <table class="table">
    <thead>
      <tr>
        <th>Datei</th>
        <th>Importiert am</th>
        <th>Neu</th>
        <th>Auto-Match</th>
        <th>Übersprungen</th>
      </tr>
    </thead>
    <tbody>
      {% for entry in history %}
      <tr>
        <td class="text-mono">{{ entry.filename }}</td>
        <td class="text-muted">{{ entry.imported_at | date_de }}</td>
        <td>{{ entry.count_new }}</td>
        <td>{{ entry.count_matched }}</td>
        <td>{{ entry.count_skipped }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

{% include "fragments/reconciliation_nav.html.j2" %}

<div class="page-header">
  <h1 class="page-title">
    Zahlungsübersicht —
    {% if customer %}{{ customer.vorname }} {{ customer.nachname }}{% else %}Kunde {{ customer_id }}{% endif %}
  </h1>
</div>

{% if invoices %}
<table class="table">
  <thead>
    <tr>
      <th>Rechnung</th>
      <th>Zeitraum</th>
      <th>Betrag</th>
      <th>Status</th>
      <th>Zahlungsdatum</th>
      <th>Zahlung von Bank</th>
      <th>Verwendungszweck</th>
    </tr>
  </thead>
  <tbody>
    {% for inv in invoices %}
    <tr>
      <td>{{ inv.invoice_number }}</td>
      <td>{{ inv.period_start | date_de }} – {{ inv.period_end | date_de }}</td>
      <td>{{ inv.amount | euro }}</td>
      <td>{{ INVOICE_STATUS_LABELS.get(inv.effective_status, inv.effective_status) }}</td>
      <td>{{ inv.paid_at | date_de if inv.paid_at else "—" }}</td>
      <td>{{ inv.matched_tx.debtor_name if inv.matched_tx else "—" }}</td>
      <td>{{ inv.matched_tx.remittance_info if inv.matched_tx else "—" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p>Keine Rechnungen für diesen Kunden.</p>
{% endif %}

<h2 class="section-title">Nicht zugeordnete Transaktionen</h2>

<form hx-get="/reconciliation/customers/{{ customer_id }}"
      hx-target="#main-content" hx-push-url="true"
      class="tx-filter">
  <div class="tx-filter__row">
    <input type="search" name="tx_search" value="{{ tx_search }}"
           class="form-input" placeholder="Suchen…">
    <select name="tx_year" class="form-input form-input--sm">
      <option value="">Alle Jahre</option>
      {% for y in tx_years | default([]) %}
      <option value="{{ y }}" {% if y == tx_year %}selected{% endif %}>{{ y }}</option>
      {% endfor %}
    </select>
    <select name="tx_month" class="form-input form-input--sm">
      <option value="">Alle Monate</option>
      {% for m in tx_months | default([]) %}
      <option value="{{ m }}" {% if m == tx_month %}selected{% endif %}>{{ m | month_name }}</option>
      {% endfor %}
    </select>
  </div>
  <div class="tx-filter__cols">
    <span>Suche in:</span>
    {% for col, label in [("debtor_name","Auftraggeber"),("debtor_iban","IBAN"),("remittance_info","Verwendungszweck"),("transaction_id","ID")] %}
    <label><input type="checkbox" name="tx_cols" value="{{ col }}"
           {% if not tx_cols or col in tx_cols %}checked{% endif %}> {{ label }}</label>
    {% endfor %}
  </div>
  <div>
    <button type="submit" class="btn btn-primary btn-sm">Filtern</button>
  </div>
</form>

{% if unmatched_tx %}
<table class="table">
  <thead>
    <tr>
      <th>Datum</th>
      <th>Betrag</th>
      <th>Auftraggeber</th>
      <th>IBAN</th>
      <th>Verwendungszweck</th>
      <th>ID</th>
      <th>Zuweisen</th>
    </tr>
  </thead>
  <tbody>
    {% for tx in unmatched_tx %}
    <tr>
      <td>{{ tx.booking_date | date_de }}</td>
      <td>{{ tx.amount | euro }}</td>
      <td>{{ tx.debtor_name or "—" }}</td>
      <td>{{ tx.debtor_iban or "—" }}</td>
      <td>{{ tx.remittance_info or "—" }}</td>
      <td><code>{{ tx.transaction_id }}</code></td>
      <td>
        {% if open_invoices | default([]) %}
        <form hx-post="/reconciliation/customers/{{ customer_id }}/match"
              hx-target="closest tr" hx-swap="outerHTML" class="assign-form">
          <input type="hidden" name="transaction_id" value="{{ tx.transaction_id }}">
          <select name="invoice_id" class="form-input form-input--sm">
            {% for inv in open_invoices | default([]) %}
            <option value="{{ inv.id }}">{{ inv.invoice_number }}</option>
            {% endfor %}
          </select>
          <button type="submit" class="btn btn-primary btn-sm">Zuweisen</button>
        </form>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p>Keine offenen Transaktionen.</p>
{% endif %}

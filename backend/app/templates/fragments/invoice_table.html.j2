<div class="page-header">
  <h1 class="page-title">Rechnungen</h1>
</div>

<div class="filter-bar">
  <input type="number" name="year" placeholder="Jahr" class="form-input"
         value="{{ filter_year }}" style="width:100px"
         hx-get="/invoices" hx-trigger="input changed delay:500ms"
         hx-target="#invoice-table" hx-include="[name='month'],[name='status']">
  <input type="number" name="month" placeholder="Monat" class="form-input"
         value="{{ filter_month }}" style="width:90px" min="1" max="12"
         hx-get="/invoices" hx-trigger="input changed delay:500ms"
         hx-target="#invoice-table" hx-include="[name='year'],[name='status']">
  <select name="status" class="form-select"
          hx-get="/invoices" hx-trigger="change"
          hx-target="#invoice-table"
          hx-include="[name='year'],[name='month']">
    <option value="" {% if not filter_status %}selected{% endif %}>Alle Status</option>
    <option value="draft" {% if filter_status == 'draft' %}selected{% endif %}>Entwurf</option>
    <option value="sent" {% if filter_status == 'sent' %}selected{% endif %}>Versendet</option>
  </select>
</div>

<div class="card mt-2">
  <div class="card__title">Generieren</div>
  <form id="generate-form"
        hx-post="/invoices/generate"
        hx-target="#generate-status"
        hx-swap="innerHTML"
        class="form-grid">
    <div class="form-group">
      <label class="form-label" for="gen_year">Jahr</label>
      <input id="gen_year" name="year" type="number" class="form-input" style="width:100px"
             value="{{ filter_year or '' }}" required>
    </div>
    <div class="form-group">
      <label class="form-label" for="gen_month">Monat</label>
      <input id="gen_month" name="month" type="number" class="form-input" style="width:90px"
             value="{{ filter_month or '' }}" min="1" max="12" required>
    </div>
    <div class="form-group" style="align-self:flex-end">
      <button type="submit" class="btn btn--primary">Generieren</button>
    </div>
  </form>
  <div id="generate-status" class="mt-1"
       hx-ext="sse"></div>
</div>

<form id="invoice-bulk-form"
      hx-post="/invoices/bulk-delete"
      hx-target="#main-content"
      hx-push-url="true"
      hx-confirm="Ausgewählte Entwürfe wirklich löschen?">
  <div id="invoice-table">
    {% if invoices %}
    <div class="table-wrapper mt-2">
      <table class="table">
        <thead>
          <tr>
            <th><input type="checkbox" class="checkbox" id="select-all"
                       onclick="document.querySelectorAll('.inv-check').forEach(c => c.checked = this.checked)"></th>
            <th>Nummer</th>
            <th>Kunde</th>
            <th>Tarif</th>
            <th>Zeitraum</th>
            <th>Betrag</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for inv in invoices %}
          <tr id="invoice-row-{{ inv.id }}">
            <td>
              {% if inv.status == 'draft' %}
              <input type="checkbox" name="ids" value="{{ inv.id }}" class="checkbox inv-check">
              {% endif %}
            </td>
            <td class="text-mono">{{ inv.invoice_number }}</td>
            <td>{{ inv.customer_name }}</td>
            <td>{{ inv.plan_name }}</td>
            <td>{{ inv.period_start }} – {{ inv.period_end }}</td>
            <td class="text-right">{{ inv.amount | euro }}</td>
            <td>
              {% if inv.status == 'draft' %}
                <span class="badge badge--draft">Entwurf</span>
              {% else %}
                <span class="badge badge--sent">Versendet</span>
              {% endif %}
            </td>
            <td>
              <div class="table__actions">
                {% if inv.pdf_path %}
                <a href="/invoices/{{ inv.id }}/pdf" class="btn btn--sm btn--secondary">PDF</a>
                {% endif %}
                {% if inv.status == 'draft' %}
                <button class="btn btn--sm btn--primary"
                        hx-post="/invoices/{{ inv.id }}/send"
                        hx-target="#invoice-row-{{ inv.id }}"
                        hx-swap="outerHTML"
                        hx-confirm="Rechnung {{ inv.invoice_number }} jetzt versenden?">
                  Senden
                </button>
                <button class="btn btn--sm btn--danger"
                        hx-delete="/invoices/{{ inv.id }}"
                        hx-confirm="Rechnung löschen?"
                        hx-target="#invoice-row-{{ inv.id }}"
                        hx-swap="outerHTML swap:300ms">
                  Löschen
                </button>
                {% endif %}
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="form-actions mt-1" style="border:none">
      <button type="submit" class="btn btn--danger btn--sm">Auswahl löschen</button>
    </div>
    {% else %}
    <div class="table-wrapper mt-2">
      <table class="table">
        <tbody class="table--empty">
          <tr><td>Keine Rechnungen gefunden.</td></tr>
        </tbody>
      </table>
    </div>
    {% endif %}
  </div>
</form>
